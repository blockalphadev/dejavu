{
  "name": "exoduze",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:web": "pnpm --filter @exoduze/web build && cp -r apps/web/dist ./dist",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules dist",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "h3": ">=1.15.5",
      "hono": ">=4.11.4",
      "tar": ">=7.5.3",
      "qs": ">=6.14.1",
      "glob": ">=11.1.0",
      "preact": ">=10.28.2",
      "lodash": ">=4.17.23",
      "js-yaml": ">=4.1.1"
    }
  }
}